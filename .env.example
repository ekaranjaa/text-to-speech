# ── OpenReader + Kokoro text-to-speech configuration ────────────────────────
# Copy this file to `.env` (which is git-ignored) before `docker compose up`:
#     cp .env.example .env

# Host ports (change only if they collide with something else).
OPENREADER_PORT=3003
KOKORO_PORT=8880

# Public URL the browser uses to reach OpenReader — must match OPENREADER_PORT.
BASE_URL=http://localhost:3003

# Session-signing AND secrets-at-rest encryption key (mandatory in OpenReader
# v4+). Generate one with:  openssl rand -hex 32
# WARNING: this key also encrypts stored secrets — including the seeded TTS
# provider's config — inside the openreader_docstore volume. Do NOT change it
# after first boot, or existing data can no longer be decrypted and TTS fails
# with "Unsupported state or unable to authenticate data". To rotate it you must
# also wipe the volume: docker compose down -v && docker compose up -d
AUTH_SECRET=

# Admin user(s), comma-separated. The admin owns the shared TTS provider that
# anonymous users rely on. The first user matching this list becomes admin.
ADMIN_EMAILS=you@example.com
